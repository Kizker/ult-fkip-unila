APP_NAME="Web ULT FKIP Unila"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ult_fkip_fullpower
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
